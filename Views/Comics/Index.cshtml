@model List<FBZ.Encyclopedia.Web.Models.ComicRecord>

<h2>Fantasy B’zaar Comic Encyclopedia</h2>

<form method="get">
    <input type="text" name="search" placeholder="Search title..." />

    <select name="sortOrder">
        <option value="asc">Sort A-Z</option>
        <option value="desc">Sort Z-A</option>
    </select>

    <button type="submit">Apply</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Character</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var comic in Model)
        {
            <tr>
                <td>@comic.Title</td>
                <td>@comic.Character</td>
            </tr>
        }
    </tbody>
</table>